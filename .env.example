# Optional: Google OAuth web client (see credentials/google-oauth-web.json)
GOOGLE_OAUTH_PROJECT_ID=
GOOGLE_OAUTH_AUTH_URI=
GOOGLE_OAUTH_TOKEN_URI=
GOOGLE_OAUTH_AUTH_PROVIDER_X509_CERT_URL=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# If you see auth/api-key-not-valid in the browser: Google Cloud → APIs & Services →
# Credentials → your Browser API key → Application restrictions must allow this origin
# (e.g. HTTP referrers: http://localhost:3000/*) or "None" for local testing.
# Also Authentication → Settings → Authorized domains → add localhost.

# Public — safe in browser
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# App URL for Steam OpenID return_to / realm (no trailing slash)
NEXT_PUBLIC_APP_URL=

# Server-only
STEAM_API_KEY=
# Firebase Admin (API routes) — Vercel: use FIREBASE_SERVICE_ACCOUNT_JSON (JSON.stringify whole file, one line).
# Local: either that or FIREBASE_SERVICE_ACCOUNT_PATH=./credentials/firebase-adminsdk.json
