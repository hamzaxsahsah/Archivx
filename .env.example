# Optional: Google OAuth web client (see credentials/google-oauth-web.json)
GOOGLE_OAUTH_PROJECT_ID=
GOOGLE_OAUTH_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_OAUTH_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# If you see auth/api-key-not-valid in the browser: Google Cloud → APIs & Services →
# Credentials → your Browser API key → Application restrictions must allow this origin
# (e.g. HTTP referrers: http://localhost:3000/*) or "None" for local testing.
# Also Authentication → Settings → Authorized domains → add localhost.

# Public — safe in browser
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# App URL for Steam OpenID return_to / realm (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only
STEAM_API_KEY=your_steam_web_api_key
# Firebase Admin (API routes) — Vercel: use FIREBASE_SERVICE_ACCOUNT_JSON (JSON.stringify whole file, one line).
# Local: either that or FIREBASE_SERVICE_ACCOUNT_PATH=./credentials/firebase-adminsdk.json
